{
  "name": "release-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch server/main.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run typecheck && npm run build && node --test tests/release-hub.test.mjs",
    "start": "node server/main.mjs"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "5.9.3",
    "vite": "8.0.13"
  }
}
